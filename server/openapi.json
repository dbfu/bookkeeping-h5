            }
          }
        }
      },
      "delete": {
        "tags": ["分类"],
        "summary": "删除分类",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {

          }
        }
      }
    },
    "/api/family/member/{id}": {
      "delete": {
        "tags": ["家庭"],
        "summary": "移除家庭成员",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "成员ID"
          }
        ],
        "responses": {
          "200": {
            "description": "移除成功",

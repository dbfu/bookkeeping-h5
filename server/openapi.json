          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["inviteCode"],
                "properties": {
                  "inviteCode": {
                    "type": "string",
                    "description": "邀请码"
                  }
                }
              }
            }
          }
